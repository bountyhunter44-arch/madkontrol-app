{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "predeploy": [
      "node scripts/sync-tools-to-functions.cjs"
    ],
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/dashbord",
        "destination": "/dashboard",
        "type": 301
      },
      {
        "source": "/dashbord.html",
        "destination": "/dashboard",
        "type": 301
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Strict-Transport-Security",
            "value": "max-age=31536000; includeSubDomains; preload"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Content-Security-Policy",
            "value": "upgrade-insecure-requests"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/",
        "destination": "/index.html"
      },
      {
        "source": "/dashboard",
        "destination": "/dashboard.html"
      },
      {
        "source": "/dashboard.html",
        "destination": "/dashboard.html"
      },
      {
        "source": "/tak",
        "destination": "/tak.html"
      },
      {
        "source": "/tak.html",
        "destination": "/tak.html"
      },
      {
        "source": "/privatlivspolitik",
        "destination": "/privatlivspolitik.html"
      },
      {
        "source": "/vilkaar-og-betingelser",
        "destination": "/vilkaar-og-betingelser.html"
      },
      {
        "source": "/cookie-indstillinger",
        "destination": "/cookie-indstillinger.html"
      },
      {
        "source": "/gdpr",
        "destination": "/gdpr.html"
      },
      {
        "source": "/landing",
        "destination": "/index.html"
      },
      {
        "source": "/landing.html",
        "destination": "/index.html"
      },
      {
        "source": "/fn/saveRoutineTask",
        "function": "saveRoutineTask"
      },
      {
        "source": "/fn/getDashboardSnapshot",
        "function": "getDashboardSnapshot"
      },
      {
        "source": "/fn/seedDemoData",
        "function": "seedDemoData"
      },
      {
        "source": "/fn/resetDemoData",
        "function": "resetDemoData"
      },
      {
        "source": "/fn/getCloudinarySignature",
        "function": "getCloudinarySignature"
      },
      {
        "source": "/fn/analyzeCloudinaryAsset",
        "function": "analyzeCloudinaryAsset"
      },
      {
        "source": "/fn/getCloudinaryAssets",
        "function": "getCloudinaryAssets"
      },
      {
        "source": "/api/**",
        "function": "api"
      }
    ]
  },
  "functions": {
    "predeploy": [
      "node scripts/sync-tools-to-functions.cjs"
    ],
    "source": "functions",
    "runtime": "nodejs22"
  }
}
