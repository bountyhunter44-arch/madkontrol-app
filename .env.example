# Madkontrollen Pro - Environment Variables
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file to functions/.env (NOT root .env)
# 2. Fill in your actual Cloudinary credentials
# 3. Restart Firebase Emulator
#
# Get Cloudinary credentials from: https://cloudinary.com/console
# See CLOUDINARY_SETUP.md for detailed instructions

# Cloudinary Configuration (REQUIRED for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# OpenAI Configuration (OPTIONAL - for AI features)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Firebase Configuration (already in firebase-config.js)
# These are public and can be committed
FIREBASE_API_KEY=AIzaSyDNzCaPlot6hUdWDS4co91KW6isfLabTWI
FIREBASE_AUTH_DOMAIN=madkontrollen.firebaseapp.com
FIREBASE_PROJECT_ID=madkontrollen
FIREBASE_STORAGE_BUCKET=madkontrollen.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=690530462316
FIREBASE_APP_ID=1:690530462316:web:f4d3e7c8e0b1a2c3d4e5f6

# Production Settings
NODE_ENV=production
