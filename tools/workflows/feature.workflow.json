{
  "id": "feature-workflow",
  "name": "Feature Development Workflow",
  "type": "feature",
  "version": "1.0.0",
  "description": "Standard workflow for developing new features",
  "steps": [
    {
      "order": 1,
      "action": "Check registries",
      "description": "Check helper-registry, engine-registry, component-registry for existing code",
      "requiredTools": ["grep", "find"],
      "checkpoints": [
        "No duplicate helpers found",
        "No duplicate components found",
        "Dependencies understood"
      ]
    },
    {
      "order": 2,
      "action": "Design feature",
      "description": "Plan feature architecture and identify required changes",
      "requiredTools": ["ChatGPT", "Windsurf"],
      "checkpoints": [
        "Architecture documented",
        "Dependencies identified",
        "Risks assessed"
      ]
    },
    {
      "order": 3,
      "action": "Create/update registries",
      "description": "Add new helpers/components to registries BEFORE implementing",
      "requiredTools": ["text editor"],
      "checkpoints": [
        "Registry entries created",
        "Dependencies mapped",
        "Schemas validated"
      ]
    },
    {
      "order": 4,
      "action": "Implement feature",
      "description": "Write code following reuse-first principles",
      "requiredTools": ["Windsurf", "Codex"],
      "checkpoints": [
        "Code follows existing patterns",
        "No duplicates created",
        "Minimal changes made"
      ]
    },
    {
      "order": 5,
      "action": "Test locally",
      "description": "Test feature in local environment",
      "requiredTools": ["firebase serve", "browser"],
      "checkpoints": [
        "Feature works as expected",
        "No console errors",
        "Existing features still work"
      ]
    },
    {
      "order": 6,
      "action": "Update documentation",
      "description": "Update README, comments, and knowledge base",
      "requiredTools": ["text editor"],
      "checkpoints": [
        "Code commented",
        "README updated",
        "Knowledge base updated"
      ]
    },
    {
      "order": 7,
      "action": "Deploy",
      "description": "Deploy to production following deploy workflow",
      "requiredTools": ["firebase CLI"],
      "checkpoints": [
        "Hosting deployed",
        "Functions deployed (if needed)",
        "Production verified"
      ]
    },
    {
      "order": 8,
      "action": "Log completion",
      "description": "Log feature completion and decisions made",
      "requiredTools": ["text editor"],
      "checkpoints": [
        "Decisions logged",
        "Completion logged",
        "Lessons learned documented"
      ]
    }
  ],
  "prerequisites": [
    "AGENT_START_RULES.md read",
    "Registries checked",
    "Feature requirements clear"
  ],
  "verification": [
    "All tests pass",
    "No duplicate code",
    "Registries updated",
    "Documentation complete",
    "Production verified"
  ],
  "tags": ["feature", "development", "standard"]
}
