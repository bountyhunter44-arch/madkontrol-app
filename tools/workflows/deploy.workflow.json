{
  "id": "deploy-workflow",
  "name": "Deployment Workflow",
  "type": "deploy",
  "version": "1.0.0",
  "description": "Standard workflow for deploying to production",
  "steps": [
    {
      "order": 1,
      "action": "Pre-deployment check",
      "description": "Verify all changes are committed and tested",
      "requiredTools": ["git"],
      "checkpoints": [
        "All changes committed",
        "No uncommitted files",
        "Tests pass locally"
      ]
    },
    {
      "order": 2,
      "action": "Syntax verification",
      "description": "Run syntax checks on all modified files",
      "requiredTools": ["node"],
      "checkpoints": [
        "HTML syntax valid",
        "JS syntax valid",
        "JSON syntax valid"
      ]
    },
    {
      "order": 3,
      "action": "Local testing",
      "description": "Test all changes in local environment",
      "requiredTools": ["firebase serve", "browser"],
      "checkpoints": [
        "All features work",
        "No console errors",
        "UI renders correctly"
      ]
    },
    {
      "order": 4,
      "action": "Deploy functions (if needed)",
      "description": "Deploy Firebase Functions if backend changes made",
      "requiredTools": ["firebase CLI"],
      "checkpoints": [
        "Functions deployed",
        "No deployment errors",
        "Functions responding"
      ]
    },
    {
      "order": 5,
      "action": "Deploy hosting",
      "description": "Deploy Firebase Hosting",
      "requiredTools": ["firebase CLI"],
      "checkpoints": [
        "Hosting deployed",
        "No deployment errors",
        "Files uploaded"
      ]
    },
    {
      "order": 6,
      "action": "Production verification",
      "description": "Verify deployment in production",
      "requiredTools": ["browser", "firebase console"],
      "checkpoints": [
        "Site loads correctly",
        "All features work",
        "No console errors"
      ]
    },
    {
      "order": 7,
      "action": "Monitor",
      "description": "Monitor for errors in first 15 minutes",
      "requiredTools": ["firebase console", "browser"],
      "checkpoints": [
        "No errors in logs",
        "No user reports",
        "Performance normal"
      ]
    },
    {
      "order": 8,
      "action": "Log deployment",
      "description": "Log deployment details",
      "requiredTools": ["text editor"],
      "checkpoints": [
        "Deployment logged",
        "Changes documented",
        "Version updated"
      ]
    }
  ],
  "prerequisites": [
    "All changes tested locally",
    "All changes committed",
    "No known bugs"
  ],
  "verification": [
    "Production site works",
    "No errors in console",
    "All features functional",
    "Deployment logged"
  ],
  "tags": ["deploy", "production", "standard"]
}
