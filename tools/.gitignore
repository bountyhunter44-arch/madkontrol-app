# Tools Platform .gitignore

# Memory folders (user-specific data)
memory/knowledge/*
memory/prompts/*
memory/operations/*
memory/ideas/*
memory/decisions/*

# Keep folder structure
!memory/knowledge/.gitkeep
!memory/prompts/.gitkeep
!memory/operations/.gitkeep
!memory/ideas/.gitkeep
!memory/decisions/.gitkeep

# Desktop app old monolithic file (replaced by modules)
desktop-app/public/desktop-modules.js

# Scanners (future phase)
scanners/*
!scanners/.gitkeep

# Temporary files
*.tmp
*.temp
*.log

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
