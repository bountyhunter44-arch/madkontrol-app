{
  "version": "1.0.0",
  "description": "Test data for reportEntryResolver.js - covers all edge cases",
  "testCases": [
    {
      "name": "Normal completed entry",
      "entry": {
        "id": "entry_001",
        "createdAt": "2026-05-11T10:00:00Z",
        "completedAt": "2026-05-11T10:30:00Z",
        "completedByName": "John Doe",
        "createdByName": "System",
        "status": "completed",
        "category": "Temperaturkontrol",
        "templateKey": "koeleskab_temperatur",
        "measurement": "4°C",
        "note": "Alt OK",
        "equipmentName": "Køleskab 1"
      },
      "instance": null,
      "expectedWarnings": [],
      "expectedTitle": "Køleskab temp.",
      "expectedPerformer": "John Doe",
      "expectedCategory": "Temperaturkontrol"
    },
    {
      "name": "Entry with only dateKey",
      "entry": {
        "id": "entry_002",
        "dateKey": "2026-05-10",
        "completedByName": "Jane Smith",
        "templateKey": "varemodtagelse",
        "note": "Varer modtaget"
      },
      "instance": null,
      "expectedWarnings": ["fallback_datekey_used", "missing_created_at", "missing_completed_at"],
      "expectedTitle": "Varemodtagelse",
      "expectedPerformer": "Jane Smith",
      "expectedCategory": "Varemodtagelse"
    },
    {
      "name": "Entry with taskInstance nested fields",
      "entry": {
        "id": "entry_003",
        "taskInstance": {
          "createdAt": "2026-05-11T09:00:00Z",
          "completedAt": "2026-05-11T09:45:00Z"
        },
        "completedByName": "Bob Johnson",
        "templateKey": "opvarmning",
        "measurement": "78°C"
      },
      "instance": null,
      "expectedWarnings": ["used_nested_instance"],
      "expectedTitle": "Opvarmning",
      "expectedPerformer": "Bob Johnson",
      "expectedCategory": "Opvarmning"
    },
    {
      "name": "Alert entry",
      "entry": {
        "id": "alert_001",
        "createdAt": "2026-05-11T11:00:00Z",
        "correctiveActionCompletedAt": "2026-05-11T11:30:00Z",
        "completedByName": "Alice Brown",
        "category": "Afvigelse",
        "note": "Temperatur for høj - korrigeret"
      },
      "instance": null,
      "expectedWarnings": [],
      "expectedPerformer": "Alice Brown",
      "expectedCategory": "Afvigelse"
    },
    {
      "name": "Entry with missing performer",
      "entry": {
        "id": "entry_004",
        "createdAt": "2026-05-11T08:00:00Z",
        "completedAt": "2026-05-11T08:15:00Z",
        "templateKey": "rengoering",
        "note": "Rengøring udført"
      },
      "instance": null,
      "expectedWarnings": ["missing_performer"],
      "expectedPerformer": "Ukendt",
      "expectedCategory": "Rengøring"
    },
    {
      "name": "Entry with mixed timestamp fields",
      "entry": {
        "id": "entry_005",
        "createdAtClient": "2026-05-11T07:00:00Z",
        "documentedAt": "2026-05-11T07:30:00Z",
        "performedAt": "2026-05-11T07:25:00Z",
        "responsibleName": "Charlie Wilson",
        "templateKey": "nedkoeling",
        "measurement": "8°C"
      },
      "instance": null,
      "expectedWarnings": ["used_client_timestamp", "used_documented_at", "used_responsible_name"],
      "expectedPerformer": "Charlie Wilson",
      "expectedCategory": "Nedkøling"
    },
    {
      "name": "Entry with separate instance parameter",
      "entry": {
        "id": "entry_006",
        "completedByName": "Diana Prince",
        "templateKey": "varmholdelse",
        "measurement": "67°C"
      },
      "instance": {
        "createdAt": "2026-05-11T12:00:00Z",
        "completedAt": "2026-05-11T12:30:00Z",
        "status": "completed"
      },
      "expectedWarnings": ["used_separate_instance"],
      "expectedPerformer": "Diana Prince",
      "expectedCategory": "Varmholdelse"
    },
    {
      "name": "Entry with only updatedAt",
      "entry": {
        "id": "entry_007",
        "updatedAt": "2026-05-11T14:00:00Z",
        "performedByName": "Eve Adams",
        "templateKey": "tre_timers",
        "note": "3-timers regel overholdt"
      },
      "instance": null,
      "expectedWarnings": ["missing_created_at", "fallback_updated_at"],
      "expectedPerformer": "Eve Adams",
      "expectedCategory": "3-timers regel"
    },
    {
      "name": "Entry with email as performer",
      "entry": {
        "id": "entry_008",
        "createdAt": "2026-05-11T15:00:00Z",
        "completedAt": "2026-05-11T15:20:00Z",
        "userEmail": "frank@example.com",
        "templateKey": "adskillelse"
      },
      "instance": null,
      "expectedWarnings": ["used_email_as_name"],
      "expectedPerformer": "frank@example.com",
      "expectedCategory": "Adskillelse"
    },
    {
      "name": "Entry with uid as performer",
      "entry": {
        "id": "entry_009",
        "createdAt": "2026-05-11T16:00:00Z",
        "completedAt": "2026-05-11T16:10:00Z",
        "uid": "abc123def456ghi789",
        "templateKey": "allergener"
      },
      "instance": null,
      "expectedWarnings": ["used_uid_as_name"],
      "expectedPerformer": "abc123de...",
      "expectedCategory": "Allergener"
    },
    {
      "name": "Entry with Firestore Timestamp objects",
      "entry": {
        "id": "entry_010",
        "createdAt": {
          "_seconds": 1715428800,
          "_nanoseconds": 0,
          "toDate": "function"
        },
        "completedAt": {
          "_seconds": 1715430600,
          "_nanoseconds": 0,
          "toDate": "function"
        },
        "completedByName": "Grace Lee",
        "templateKey": "opbevaring"
      },
      "instance": null,
      "expectedWarnings": [],
      "expectedPerformer": "Grace Lee",
      "expectedCategory": "Opbevaring",
      "note": "Firestore Timestamp objects should be handled via toDate()"
    },
    {
      "name": "Entry with no timestamps at all",
      "entry": {
        "id": "entry_011",
        "completedByName": "Henry Ford",
        "templateKey": "personlig_hygiejne",
        "note": "Hygiejne kontrolleret"
      },
      "instance": null,
      "expectedWarnings": ["missing_created_at", "missing_completed_at"],
      "expectedPerformer": "Henry Ford",
      "expectedCategory": "Personlig hygiejne"
    },
    {
      "name": "Entry with ambiguous timestamps",
      "entry": {
        "id": "entry_012",
        "createdAt": "2026-05-11T10:00:00Z",
        "createdAtClient": "2026-05-11T10:05:00Z",
        "entryCreatedAt": "2026-05-11T10:10:00Z",
        "completedAt": "2026-05-11T10:30:00Z",
        "completedAtClient": "2026-05-11T10:35:00Z",
        "completedByName": "Ivy Chen",
        "templateKey": "sporbarhed"
      },
      "instance": null,
      "expectedWarnings": [],
      "expectedPerformer": "Ivy Chen",
      "expectedCategory": "Sporbarhed",
      "note": "Should use createdAt (priority 1) and completedAt (priority 1)"
    },
    {
      "name": "Minimal entry with defaults",
      "entry": {
        "id": "entry_013"
      },
      "instance": null,
      "expectedWarnings": ["missing_created_at", "missing_completed_at", "missing_performer", "missing_category"],
      "expectedPerformer": "Ukendt",
      "expectedCategory": "Egenkontrol"
    },
    {
      "name": "Entry with inferred status",
      "entry": {
        "id": "entry_014",
        "createdAt": "2026-05-11T17:00:00Z",
        "completedAt": "2026-05-11T17:30:00Z",
        "completedByName": "Jack Ryan",
        "templateKey": "koeleskab_temperatur"
      },
      "instance": null,
      "expectedWarnings": ["inferred_from_timestamp"],
      "expectedStatus": "completed",
      "expectedPerformer": "Jack Ryan"
    }
  ],
  "edgeCases": {
    "nullEntry": {
      "description": "normalizeReportEntry(null) should return safe defaults",
      "expectedTitle": "Ukendt opgave",
      "expectedPerformer": "Ukendt",
      "expectedWarnings": ["missing_entry"]
    },
    "undefinedEntry": {
      "description": "normalizeReportEntry(undefined) should return safe defaults",
      "expectedTitle": "Ukendt opgave",
      "expectedPerformer": "Ukendt",
      "expectedWarnings": ["missing_entry"]
    },
    "invalidDateFormats": {
      "description": "Invalid date strings should return null",
      "testValues": ["invalid", "2026-13-45", "not-a-date", 0, false, {}]
    },
    "emptyStrings": {
      "description": "Empty strings should be treated as missing",
      "testValues": ["", "   ", "\t", "\n"]
    }
  }
}
