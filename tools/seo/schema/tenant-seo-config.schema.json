{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tenant SEO Config",
  "type": "object",
  "required": ["tenantId", "domain", "language", "country"],
  "properties": {
    "tenantId": { "type": "string" },
    "productId": { "type": "string" },
    "domain": { "type": "string" },
    "language": { "type": "string" },
    "country": { "type": "string" },
    "industry": { "type": "string" },
    "audience": { "type": "string" },
    "tone": { "type": "string" },
    "topics": { "type": "array", "items": { "type": "string" } },
    "blockedTopics": { "type": "array", "items": { "type": "string" } },
    "publisher": {
      "type": "string",
      "enum": ["firestore-draft", "firebase-hosting", "vps-static", "wordpress", "future-social"]
    },
    "requireHumanApproval": { "type": "boolean" },
    "billingPlan": { "type": "string" },
    "monthlyPageLimit": { "type": "number" },
    "channels": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
