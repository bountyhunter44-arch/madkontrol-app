{
  "project": "Madkontrollen Pro",
  "version": 1,
  "principles": [
    "toolbox-first",
    "reuse-first",
    "canonical-first",
    "small-diff"
  ],
  "protectedSystems": [
    "stripe",
    "auth",
    "firestore-rules",
    "subscription-flow",
    "live-user-profiles-contract"
  ],
  "directories": [
    {
      "path": "public/core",
      "role": "shared browser helpers and canonical UI contracts",
      "requiredBeforeEdit": [
        "read docs/AI_TOOLBOX.md",
        "inspect tools/registries/helper-registry.json"
      ]
    },
    {
      "path": "public/modules/egenkontrol",
      "role": "egenkontrol UI, reporting, routines, onboarding, and risk analysis flows",
      "requiredBeforeEdit": [
        "read relevant registry stamps",
        "search existing helpers before adding local fallbacks"
      ]
    },
    {
      "path": "functions",
      "role": "Firebase Cloud Functions, provisioning, Stripe, and backend task engines",
      "protected": true,
      "requiredBeforeEdit": [
        "verify whether Stripe/Auth/subscription logic is involved",
        "avoid Firestore contract changes unless explicitly requested"
      ]
    },
    {
      "path": "functions/js",
      "role": "backend canonical routine model helpers"
    },
    {
      "path": "tools",
      "role": "AI agent registries, workflows, scanners, and documentation tooling"
    }
  ],
  "helpers": [
    {
      "name": "createAuditCompleteFields",
      "file": "public/core/auditFields.js",
      "purpose": "canonical completion audit field construction",
      "mustReuseFor": [
        "task completion audit fields",
        "completedByName and completedByEmail writes"
      ]
    },
    {
      "name": "resolveEntryActor",
      "file": "public/core/reportEntryResolver.js",
      "purpose": "canonical report actor normalization with company-name blocking",
      "mustReuseFor": [
        "Udfort af rendering",
        "employee filters",
        "report actor fallbacks"
      ]
    },
    {
      "name": "resolveTaskTitle",
      "file": "public/core/taskTitleResolver.js",
      "purpose": "canonical task title display resolver"
    },
    {
      "name": "resolveTaskTitleWithContext",
      "file": "public/core/taskTitleResolver.js",
      "purpose": "task title resolver with equipment and area context"
    },
    {
      "name": "resolvePrettyCompanyInfo",
      "file": "public/core/prettyName.js",
      "purpose": "canonical company and location display resolver"
    },
    {
      "name": "resolveCompanyIdFromUserData",
      "file": "public/core/prettyName.js",
      "purpose": "canonical company id extraction through org context"
    },
    {
      "name": "resolveLocationIdFromUserData",
      "file": "public/core/prettyName.js",
      "purpose": "canonical location id extraction through org context"
    },
    {
      "name": "resolveOrgContext",
      "file": "public/core/auth.js",
      "purpose": "canonical org, company, and location context resolver"
    },
    {
      "name": "normalizeTaskKey",
      "file": "public/core/canonicalTasks.js",
      "purpose": "browser canonical task key normalizer"
    },
    {
      "name": "getCanonicalTask",
      "file": "public/core/canonicalTasks.js",
      "purpose": "browser canonical task lookup"
    },
    {
      "name": "normalizeRoutineType",
      "file": "functions/js/canonicalRoutines.js",
      "purpose": "backend canonical routine type normalizer"
    },
    {
      "name": "buildCanonicalTaskKey",
      "file": "functions/js/canonicalRoutines.js",
      "purpose": "backend canonical task key builder"
    },
    {
      "name": "generateCanonicalTaskTemplates",
      "file": "functions/canonicalTaskEngine.js",
      "purpose": "backend canonical task template generation"
    },
    {
      "name": "ensureSingleTaskInstance",
      "file": "functions/canonicalTaskEngine.js",
      "purpose": "backend task instance dedupe"
    },
    {
      "name": "startDayForLocationCanonical",
      "file": "functions/canonicalTaskEngine.js",
      "purpose": "backend canonical daily task generation"
    },
    {
      "name": "riskAnalysisService helpers",
      "file": "public/modules/egenkontrol/riskAnalysisService.js",
      "purpose": "browser risk analysis loading and persistence helpers"
    }
  ],
  "canonicalSystems": [
    {
      "name": "canonical task engine",
      "files": [
        "functions/canonicalTaskEngine.js",
        "functions/js/canonicalRoutines.js",
        "public/core/canonicalTasks.js",
        "public/core/taskTitleResolver.js"
      ],
      "owns": [
        "routine identity",
        "template generation",
        "daily task instance dedupe",
        "task display titles"
      ]
    },
    {
      "name": "audit contracts",
      "files": [
        "public/core/auditFields.js",
        "public/core/reportEntryResolver.js"
      ],
      "owns": [
        "created/completed audit fields",
        "report actor normalization",
        "company-name blocking for employee display"
      ]
    },
    {
      "name": "prettyName system",
      "files": [
        "public/core/prettyName.js"
      ],
      "owns": [
        "company display information",
        "location display information",
        "live_user_profiles display fallback priority"
      ]
    },
    {
      "name": "onboarding profile contract",
      "files": [
        "public/onboarding.html",
        "public/quick-onboarding.html",
        "public/modules/egenkontrol/onboarding.html",
        "functions/index.js"
      ],
      "owns": [
        "companyName branding fields",
        "contactPersonName/profilename person fields",
        "checkout provisioning handoff"
      ]
    },
    {
      "name": "authority reports",
      "files": [
        "public/modules/egenkontrol/rapporter.html",
        "public/core/reportEntryResolver.js",
        "public/core/taskTitleResolver.js"
      ],
      "owns": [
        "authority-facing report rendering",
        "entry actor display",
        "task title display"
      ]
    }
  ],
  "criticalFlows": [
    {
      "name": "full onboarding checkout provisioning",
      "protectedSystems": [
        "stripe",
        "auth",
        "live-user-profiles-contract",
        "subscription-flow"
      ]
    },
    {
      "name": "quick onboarding account creation",
      "protectedSystems": [
        "auth",
        "live-user-profiles-contract"
      ]
    },
    {
      "name": "task completion and audit write",
      "collections": [
        "task_instances",
        "task_entries",
        "alerts"
      ],
      "mustUseHelpers": [
        "createAuditCompleteFields"
      ]
    },
    {
      "name": "canonical day start",
      "collections": [
        "task_templates",
        "task_instances"
      ],
      "mustUseHelpers": [
        "startDayForLocationCanonical",
        "ensureSingleTaskInstance"
      ]
    },
    {
      "name": "authority report rendering",
      "collections": [
        "task_entries",
        "task_instances",
        "haccp_snapshots",
        "alerts"
      ],
      "mustUseHelpers": [
        "resolveEntryActor",
        "resolveTaskTitle",
        "resolvePrettyCompanyInfo"
      ]
    },
    {
      "name": "Stripe subscription webhook",
      "protectedSystems": [
        "stripe",
        "subscription-flow"
      ]
    }
  ]
}
