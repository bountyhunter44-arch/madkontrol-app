{
  "project": "PolicyBridge AI Podcast Station",
  "version": 1,
  "status": "planning-only",
  "scope": "structure-tooling-docs",
  "modules": [
    {
      "id": "debate-room",
      "name": "Debate Room",
      "owner": "future frontend experience",
      "status": "concept",
      "responsibilities": [
        "host structured human plus AI debate sessions",
        "display participant roles and constraints",
        "surface uncertainty, unresolved disagreement, and source gaps"
      ],
      "mustNotOwn": [
        "auth",
        "payments",
        "persistent production storage",
        "realtime voice infrastructure"
      ]
    },
    {
      "id": "ai-participant-orchestrator",
      "name": "AI Participant Orchestrator",
      "owner": "future AI runtime",
      "status": "concept",
      "responsibilities": [
        "select AI participant profiles",
        "enforce profile boundaries",
        "prevent authority theater",
        "route prompts to synthesis and moderation layers"
      ],
      "mustNotOwn": [
        "user identity",
        "billing",
        "unreviewed public claims"
      ]
    },
    {
      "id": "synthesis-engine",
      "name": "Synthesis Engine",
      "owner": "future AI reasoning layer",
      "status": "concept",
      "responsibilities": [
        "summarize positions",
        "detect overlap and compromise zones",
        "separate evidence from inference",
        "track unresolved questions"
      ],
      "mustNotOwn": [
        "final political judgment",
        "source-of-truth authority",
        "private moderation decisions"
      ]
    },
    {
      "id": "moderation-layer",
      "name": "Moderation Layer",
      "owner": "future safety and trust layer",
      "status": "concept",
      "responsibilities": [
        "enforce debate rules",
        "label harmful or low-quality dynamics",
        "support human moderator override",
        "preserve viewpoint pluralism without amplifying abuse"
      ],
      "mustNotOwn": [
        "ideological gatekeeping",
        "opaque ranking decisions"
      ]
    },
    {
      "id": "public-transparency-ledger",
      "name": "Public Transparency Ledger",
      "owner": "future trust architecture",
      "status": "concept",
      "responsibilities": [
        "describe AI roles",
        "show summary methods",
        "record uncertainty and correction notices",
        "publish moderation principles"
      ],
      "mustNotOwn": [
        "private user data",
        "unredacted internal prompts",
        "security-sensitive configuration"
      ]
    }
  ]
}

