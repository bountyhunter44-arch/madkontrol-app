{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Relationship Schema",
  "description": "Schema for documenting relationships between code entities",
  "type": "object",
  "required": ["from", "to", "type"],
  "properties": {
    "from": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": {"type": "string"},
        "type": {
          "type": "string",
          "enum": ["helper", "engine", "component", "module"]
        }
      }
    },
    "to": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": {"type": "string"},
        "type": {
          "type": "string",
          "enum": ["helper", "engine", "component", "module"]
        }
      }
    },
    "type": {
      "type": "string",
      "enum": ["depends-on", "uses", "calls", "imports", "extends"],
      "description": "Type of relationship"
    },
    "description": {
      "type": "string",
      "description": "Description of the relationship"
    },
    "critical": {
      "type": "boolean",
      "description": "Whether this relationship is critical and must not be broken"
    }
  }
}
